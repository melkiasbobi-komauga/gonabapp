PORT=3000
NODE_ENV=development

# ─── PostgreSQL + PostGIS ──────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gonab_db
DB_USER=gonab_user
DB_PASSWORD=gonab2024secure
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=5000

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET=gonab_super_secret_jwt_key_nabire_papua_tengah_2024
JWT_EXPIRES_IN=7d

# ─── App ──────────────────────────────────────────────────────
APP_NAME=GONAB
APP_VERSION=1.0.0
BASE_URL=http://localhost:3000

# ─── Google Maps Platform ─────────────────────────────────────
# Ganti dengan API key asli dari https://console.cloud.google.com/
# APIs yang perlu diaktifkan:
#   - Maps JavaScript API        (untuk peta web & admin dashboard)
#   - Maps SDK for Android/iOS   (untuk Flutter app)
#   - Directions API             (rute & navigasi driver)
#   - Distance Matrix API        (hitung jarak & estimasi ongkos)
#   - Geocoding API              (alamat ↔ koordinat)
#   - Places API                 (autocomplete alamat)
#   - Roads API                  (snap-to-road untuk tracking)
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY

# Batas radius default pencarian driver (km)
DRIVER_SEARCH_RADIUS_KM=3
# Batas SOS radius notifikasi (km)
SOS_ALERT_RADIUS_KM=10
# Default center kota Nabire
NABIRE_LAT=-3.3667
NABIRE_LNG=135.4967

# ─── OTP / SMS (opsional, aktifkan saat produksi) ─────────────
# OTP_PROVIDER=twilio          # twilio | wablas | fonnte
# TWILIO_ACCOUNT_SID=ACxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxx
# TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
# WABLAS_TOKEN=xxxxxxx
# WABLAS_SECRET=xxxxxxx

# ─── Payment Gateway (opsional) ───────────────────────────────
# MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxx
# MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxx
# MIDTRANS_IS_PRODUCTION=false
# XENDIT_SECRET_KEY=xnd_development_xxxxxxx

# ─── File Upload ──────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# ─── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
